root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{html,astro}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.css]
indent_size = 2

[*.{js,ts,mjs}]
indent_size = 2
