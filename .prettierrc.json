{
    "useTabs": false,
    "tabWidth": 4,
    "plugins": ["prettier-plugin-astro"],
    "overrides": [
        {
            "files": "*.astro",
            "options": {
                "parser": "astro",
                "tabWidth": 4
            }
        },
        {
            "files": "*.{html,astro}",
            "options": {
                "tabWidth": 4
            }
        },
        {
            "files": "*.{yml,yaml}",
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": "*.css",
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": "*.{js,ts,mjs}",
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
