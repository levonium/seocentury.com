---
import Base from "../layouts/Base.astro";
---

<Base
    title="Page Not Found | SEO Century"
    canonical="https://seocentury.com/404/"
>
    <section class="error-section">
        <div class="error-container">
            <h1>404</h1>
            <h2>Page not found</h2>
            <p>
                We couldn't find the page you're looking for. It might have been
                moved or deleted.
            </p>
            <div class="error-ctas">
                <a href="/" class="btn-primary">Go Home</a>
                <a href="/blog/" class="btn-secondary">View Blog</a>
            </div>
        </div>
    </section>
</Base>

<style>
    .error-section {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 80px 48px;
        border-bottom: 1px solid var(--border);
    }

    .error-container {
        text-align: center;
        max-width: 600px;
    }

    h1 {
        font-family: var(--font-display);
        font-size: 120px;
        font-weight: 300;
        color: var(--accent);
        line-height: 1;
        margin-bottom: 24px;
    }

    h2 {
        font-family: var(--font-display);
        font-size: 42px;
        font-weight: 400;
        color: var(--text);
        margin-bottom: 16px;
    }

    p {
        font-size: 16px;
        color: var(--text-sec);
        line-height: 1.8;
        margin-bottom: 48px;
    }

    .error-ctas {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary {
        display: inline-block;
        background: var(--accent);
        padding: 16px 36px;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #0a0a0a;
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .btn-primary:hover {
        opacity: 0.85;
    }

    .btn-secondary {
        display: inline-block;
        border: 1px solid var(--border-light);
        padding: 16px 36px;
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text);
        text-decoration: none;
        transition: background 0.2s;
    }

    .btn-secondary:hover {
        background: var(--surface);
    }
</style>
